{
  "name": "text-me-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/text-me-admin/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "serve": {
      "executor": "@nx/vite:dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "text-me-admin:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "text-me-admin:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "text-me-admin:build:production",
          "hmr": false
        }
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/text-me-admin"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{projectRoot}/test-output/vitest/coverage"],
      "options": {
        "passWithNoTests": true,
        "reportsDirectory": "./test-output/vitest"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}
